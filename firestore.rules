rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             (!('favoriteTeam' in data) || data.favoriteTeam is string) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 512));
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'team1', 'team2', 'status']) &&
             data.id is string &&
             data.status in ['upcoming', 'live', 'finished'];
    }

    function isValidComment(data) {
      return data.keys().hasAll(['matchId', 'userId', 'text', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() <= 500 &&
             data.timestamp == request.time;
    }

    function isValidReaction(data) {
      return data.keys().hasAll(['matchId', 'type', 'timestamp']) &&
             data.type in ['SIX', 'FOUR', 'OUT', 'WICKET', 'CHEER', 'OOPS'] &&
             data.timestamp == request.time;
    }

    // --- Rules ---
    match /users/{uid} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(uid) && isValidUserProfile(incoming());
      allow update: if isOwner(uid) && isValidUserProfile(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'favoriteTeam', 'bio']);
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create, update, delete: if true; // Enabled for score simulation
    }

    match /matches/{matchId}/comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidComment(incoming()) && isValidId(matchId);
      allow update, delete: if isOwner(existing().userId);
    }

    match /matches/{matchId}/reactions/{reactionId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReaction(incoming()) && isValidId(matchId);
      allow update, delete: if false;
    }
  }
}
